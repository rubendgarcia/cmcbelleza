---
// src/layouts/BaseLayout.astro
import "../styles/global.css";
import Header from "../components/Header.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body class="bg-base text-dark font-sans flex flex-col min-h-screen relative overflow-x-hidden">
    
    <div class="absolute top-0 left-0 w-full h-[500px] bg-gradient-to-b from-primary/15 to-transparent -z-10 pointer-events-none"></div>
    
    <Header />
    
    <div class="flex-grow">
      <slot />
    </div>
  </body>
</html>