---
// src/pages/producto/[id].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProducts } from '../../lib/woocommerce.js';

export async function getStaticPaths() {
  const products = await getProducts();
  
  return products.map((product: any) => ({
    params: { id: product.id.toString() },
    props: { product }, 
  }));
}

// Solución TypeScript: Definimos explícitamente qué esperamos recibir en las props
interface Props {
  product: any;
}

const { product } = Astro.props;
---

<BaseLayout title={`${product.name} - CMC Belleza`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <a href="/#catalogo" class="inline-flex items-center text-dark-muted hover:text-primary mb-8 font-medium transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      Volver al catálogo
    </a>
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 bg-white/60 backdrop-blur-sm p-6 md:p-10 rounded-3xl shadow-sm border border-white/60">
      
      <div class="rounded-2xl overflow-hidden bg-white p-4 shadow-inner">
        {product.images && product.images.length > 0 ? (
          <img 
            src={product.images[0].src} 
            alt={product.name} 
            class="w-full h-auto max-h-125 object-contain rounded-xl"
          />
        ) : (
          <div class="w-full h-96 bg-gray-50 flex items-center justify-center rounded-xl">
            <span class="text-dark-muted">Sin imagen</span>
          </div>
        )}
      </div>
      
      <div class="flex flex-col justify-center">
        <h1 class="text-3xl md:text-5xl font-extrabold text-dark mb-4 leading-tight">{product.name}</h1>
        <p class="text-4xl font-black text-secondary mb-8">{product.price} €</p>
        
        <div class="prose prose-slate max-w-none text-dark-muted mb-10" set:html={product.description}></div>
        
        <button class="w-full md:w-auto px-10 py-4 bg-primary text-white text-lg font-bold rounded-full hover:bg-primary-hover hover:scale-105 hover:shadow-xl hover:shadow-primary/30 transition-all duration-300">
          Añadir al carrito
        </button>
      </div>
      
    </div>
  </div>
</BaseLayout>