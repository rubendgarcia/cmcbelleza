---
// src/pages/contacto.astro
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contacto - CMC Belleza">
    <section class="relative py-20 lg:py-28 text-center">
        <div class="max-w-3xl mx-auto px-4">
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-dark mb-6">
                Contacto
            </h1>
            <p class="text-lg text-dark-muted font-medium">
                ¿Tienes alguna duda o necesitas más información sobre nuestros productos?<br/>
                Estamos aquí para ayudarte y acompañarte en lo que necesites.
            </p>
        </div>
    </section>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
        <div class="flex flex-col lg:flex-row gap-16 lg:gap-20">

            <div class="w-full lg:w-1/2 flex flex-col justify-center">
                <h2 class="text-3xl md:text-4xl font-extrabold text-dark mb-6">
                    ¿Tienes alguna pregunta?<br/>
                    <span class="text-primary">Contáctanos!</span>
                </h2>

                <div class="space-y-6 text-dark-muted font-medium">
                    <p>
                        En <strong>CMC Belleza</strong> queremos que tu experiencia sea clara y sencilla.
                    </p>
                    <p>
                        Si necesitas información sobre nuestros productos, envíos o procesos, no dudes en ponerte en contacto con nosotros.
                    </p>
                    <p>
                        Nuestro equipo te responderá lo antes posible para ayudarte a elegir con tranquilidad los productos que mejor encajen contigo.
                    </p>
                    <p>
                        Descubre novedades, consejos y lanzamientos siguiendo a CMC Belleza en nuestras redes sociales.
                    </p>
                </div>

                <div class="mt-10 flex items-center gap-4">
                    <span class="text-sm font-bold text-dark tracking-wider">SÍGUENOS:</span>
                    <div class="flex gap-3">
                        <a href="#" class="w-10 h-10 rounded-full bg-primary/10 text-primary flex items-center justify-center hover:bg-primary hover:text-white transition-colors">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
                        </a>
                        <a href="#" class="w-10 h-10 rounded-full bg-primary/10 text-primary flex items-center justify-center hover:bg-primary hover:text-white transition-colors">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                        </a>
                    </div>
                </div>
            </div>

            <div class="w-full lg:w-1/2">
                <div class="bg-white/80 backdrop-blur-xl p-8 md:p-10 rounded-3xl shadow-sm border border-white/60">
                    <form id="contact-form" class="space-y-8">

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div class="relative">
                                <input type="text" id="name" name="name" placeholder="Tu nombre" required class="w-full bg-transparent border-b-2 border-gray-200 py-2 focus:outline-none focus:border-primary transition-colors text-dark placeholder-gray-400" />
                            </div>

                            <div class="relative">
                                <input type="email" id="email" name="email" placeholder="Correo Electrónico" required class="w-full bg-transparent border-b-2 border-gray-200 py-2 focus:outline-none focus:border-primary transition-colors text-dark placeholder-gray-400" />
                            </div>

                            <div class="relative">
                                <input type="tel" id="phone" name="phone" placeholder="Teléfono" class="w-full bg-transparent border-b-2 border-gray-200 py-2 focus:outline-none focus:border-primary transition-colors text-dark placeholder-gray-400" />
                            </div>

                            <div class="relative">
                                <input type="text" id="subject" name="subject" placeholder="Comentario" class="w-full bg-transparent border-b-2 border-gray-200 py-2 focus:outline-none focus:border-primary transition-colors text-dark placeholder-gray-400" />
                            </div>
                        </div>

                        <div class="relative pt-4">
                            <textarea id="message" name="message" rows="4" placeholder="Tu mensaje" required class="w-full bg-transparent border-b-2 border-gray-200 py-2 focus:outline-none focus:border-primary transition-colors text-dark placeholder-gray-400 resize-none"></textarea>
                        </div>

                        <button type="submit" class="w-full bg-secondary/90 hover:bg-secondary text-white font-bold py-4 rounded-full transition-all duration-300 shadow-md hover:shadow-lg mt-4 tracking-wider">
                            SEND A MESSAGE
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </main>

    <section class="max-w-5xl mx-auto px-4 pb-20">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 relative z-10">

            <div class="bg-white/90 backdrop-blur-md p-8 rounded-[2rem] shadow-lg border border-white/50 text-center flex flex-col items-center hover:-translate-y-2 transition-transform duration-300">
                <div class="w-16 h-16 rounded-full border-2 border-secondary/30 flex items-center justify-center text-secondary mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                </div>
                <h3 class="font-extrabold text-dark tracking-widest text-sm mb-2">CORREO</h3>
                <a href="mailto:soporte@cmcbelleza.shop" class="text-dark-muted hover:text-primary transition-colors">soporte@cmcbelleza.shop</a>
            </div>

            <div class="bg-white/90 backdrop-blur-md p-8 rounded-[2rem] shadow-lg border border-white/50 text-center flex flex-col items-center hover:-translate-y-2 transition-transform duration-300">
                <div class="w-16 h-16 rounded-full border-2 border-secondary/30 flex items-center justify-center text-secondary mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg>
                </div>
                <h3 class="font-extrabold text-dark tracking-widest text-sm mb-2">DIRECCIÓN</h3>
                <p class="text-dark-muted">Appenzell, SUIZA</p>
            </div>

            <div class="bg-white/90 backdrop-blur-md p-8 rounded-[2rem] shadow-lg border border-white/50 text-center flex flex-col items-center hover:-translate-y-2 transition-transform duration-300">
                <div class="w-16 h-16 rounded-full border-2 border-secondary/30 flex items-center justify-center text-secondary mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                </div>
                <h3 class="font-extrabold text-dark tracking-widest text-sm mb-2">CALL US</h3>
                <a href="tel:+41783161475" class="text-dark-muted hover:text-primary transition-colors">+41 783 1614 75</a>
            </div>

        </div>
    </section>
</BaseLayout>